{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt && python manage.py migrate --no-input",
  "builds": [
    {
      "src": "geckohub/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "geckohub/wsgi.py"
    }
  ]
}
